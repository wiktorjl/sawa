# Polygon.io API credentials (required)
POLYGON_API_KEY=your_api_key
POLYGON_S3_ACCESS_KEY=your_s3_access_key_here
POLYGON_S3_SECRET_KEY=your_s3_secret_key_here

# FRED API key (required for market internals: VIX, VIX3M, HY spread).
# Free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# PostgreSQL connection
DATABASE_URL=postgresql://user:password@localhost:5432/postgres

# Alternative PostgreSQL config (used if DATABASE_URL not set)
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=stock_data
# PGUSER=postgres
# PGPASSWORD=your_password_here

# Optional: push notifications for scheduler / pipeline alerts
# NTFY_TOPIC=https://ntfy.sh/your-topic

# MCP Server settings (optional)
# MCP_LOG_LEVEL=info
# MCP_MAX_ROWS=1000
# MCP_QUERY_TIMEOUT=30
